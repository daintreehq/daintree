# Fireworks AI (used for AI-powered features)
FIREWORKS_AI_KEY=

# Cloudflare R2 (release artifact publishing)
R2_TOKEN=
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET=daintree-updates
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# macOS Code Signing (base64-encoded .p12 certificate)
MAC_CERTS=
MAC_CERTS_PASSWORD=
APPLE_TEAM_ID=

# App Store Connect API Key (notarization)
# APPLE_API_KEY_ID = Key ID (10 chars) from App Store Connect
# APPLE_API_ISSUER = Issuer UUID from App Store Connect
# APPLE_API_KEY_PATH = Path to local .p8 file (ignored if APPLE_API_KEY is set)
APPLE_API_KEY_ID=
APPLE_API_ISSUER=
APPLE_API_KEY_PATH=./keys/AuthKey_YOURKEYID.p8

# OpenAI (used for voice transcription via Realtime API)
OPENAI_API_KEY=

# Claude Code (used by E2E tests to authenticate the agent)
ANTHROPIC_API_KEY=
