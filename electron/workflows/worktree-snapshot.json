{
  "id": "worktree-snapshot",
  "version": "1.0.0",
  "name": "Worktree Snapshot",
  "description": "List worktrees, get current worktree details, and create a summary note",
  "nodes": [
    {
      "id": "list-worktrees",
      "type": "action",
      "config": {
        "actionId": "worktree.list"
      },
      "onSuccess": ["get-current"],
      "onFailure": ["note-snapshot-error"]
    },
    {
      "id": "get-current",
      "type": "action",
      "config": {
        "actionId": "worktree.getCurrent"
      },
      "dependencies": ["list-worktrees"],
      "onSuccess": ["create-snapshot-note"],
      "onFailure": ["note-snapshot-error"]
    },
    {
      "id": "create-snapshot-note",
      "type": "action",
      "config": {
        "actionId": "notes.create",
        "args": {
          "title": "Worktree Snapshot",
          "content": "Worktree snapshot captured successfully. Review worktree state in the sidebar."
        }
      },
      "dependencies": ["get-current"]
    },
    {
      "id": "note-snapshot-error",
      "type": "action",
      "config": {
        "actionId": "notes.create",
        "args": {
          "title": "Worktree Snapshot Failed",
          "content": "Failed to capture worktree snapshot. An error occurred while querying worktree state."
        }
      }
    }
  ]
}
