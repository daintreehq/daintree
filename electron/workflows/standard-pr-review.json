{
  "id": "standard-pr-review",
  "version": "1.0.0",
  "name": "Standard PR Review",
  "description": "Open a terminal, run lint and tests, request approval, then refresh and open PRs",
  "nodes": [
    {
      "id": "open-terminal",
      "type": "action",
      "config": {
        "actionId": "terminal.new"
      },
      "onSuccess": ["run-lint"],
      "onFailure": ["note-terminal-error"]
    },
    {
      "id": "run-lint",
      "type": "action",
      "config": {
        "actionId": "terminal.sendCommand",
        "args": {
          "terminalId": "{{open-terminal.data.terminalId}}",
          "command": "npm run lint"
        }
      },
      "dependencies": ["open-terminal"],
      "onSuccess": ["run-tests"],
      "onFailure": ["note-lint-failure"]
    },
    {
      "id": "run-tests",
      "type": "action",
      "config": {
        "actionId": "terminal.sendCommand",
        "args": {
          "terminalId": "{{open-terminal.data.terminalId}}",
          "command": "npm test"
        }
      },
      "dependencies": ["run-lint"],
      "onSuccess": ["review"],
      "onFailure": ["note-test-failure"]
    },
    {
      "id": "review",
      "type": "approval",
      "config": {
        "prompt": "Lint and tests passed. Review the changes and approve to merge, or reject to address review comments."
      },
      "dependencies": ["run-tests"],
      "onSuccess": ["refresh-prs"],
      "onFailure": ["note-review-rejected"]
    },
    {
      "id": "refresh-prs",
      "type": "action",
      "config": {
        "actionId": "worktree.refreshPullRequests"
      },
      "dependencies": ["review"],
      "onSuccess": ["open-prs"]
    },
    {
      "id": "open-prs",
      "type": "action",
      "config": {
        "actionId": "github.openPRs"
      },
      "dependencies": ["refresh-prs"]
    },
    {
      "id": "note-terminal-error",
      "type": "action",
      "config": {
        "actionId": "notes.create",
        "args": {
          "title": "PR Review - Terminal Error",
          "content": "Failed to open a terminal for the PR review workflow."
        }
      }
    },
    {
      "id": "note-lint-failure",
      "type": "action",
      "config": {
        "actionId": "notes.create",
        "args": {
          "title": "PR Review - Lint Failed",
          "content": "Lint errors were detected. Fix linting issues before continuing the review."
        }
      }
    },
    {
      "id": "note-test-failure",
      "type": "action",
      "config": {
        "actionId": "notes.create",
        "args": {
          "title": "PR Review - Tests Failed",
          "content": "Tests failed during the PR review workflow. Fix failing tests before continuing."
        }
      }
    },
    {
      "id": "note-review-rejected",
      "type": "action",
      "config": {
        "actionId": "notes.create",
        "args": {
          "title": "PR Review - Review Rejected",
          "content": "Review was rejected. Address the review comments before retrying."
        }
      }
    }
  ]
}
